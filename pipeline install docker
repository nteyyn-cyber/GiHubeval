pipeline {
    agent any
    stages {
        stage('Install Docker') {
            steps {
                sh 'apt update -y'
                sh 'apt install -y docker.io'
                sh 'systemctl unmask docker'
                sh 'systemctl start docker'
                sh 'systemctl enable docker'
                sh 'chmod 666 /var/run/docker.sock'
                sh 'docker --version'
                sh 'docker ps'
            }
        }
    }
}
